#!/usr/bin/env bash
set -e

# 项目目录
PROJECT_DIR="your_file_path/strategy"
SERVICE_NAME="smctrade.service"

# 允许用户在项目根目录放置 smctrade.env 以设置 BINANCE_API_KEY/BINANCE_API_SECRET
ENV_FILE="$PROJECT_DIR/smctrade.env"
if [[ -f "$ENV_FILE" ]]; then
  set -a
  source "$ENV_FILE"
  set +a
fi

# 启动 systemd 用户服务，如果可用则优先使用 --user
if command -v systemctl >/dev/null 2>&1; then
  if systemctl --user status "$SERVICE_NAME" >/dev/null 2>&1; then
    echo "正在启动 smctrade 服务..."
    systemctl --user start "$SERVICE_NAME"
    echo "smctrade 已启动。"
    exit 0
  fi
fi

# fallback: 直接启动脚本（不推荐用于长期运行）
if [[ -f "$PROJECT_DIR/venv/bin/activate" ]]; then
  echo "systemd 用户服务不可用，改为直接启动进程。"
  source "$PROJECT_DIR/venv/bin/activate"
  cd "$PROJECT_DIR"
  exec python main.py -l --config config_enhanced.json
else
  echo "错误：找不到虚拟环境 $PROJECT_DIR/venv。"
  exit 1
fi
